    "section_custom_code_tgahDR": {
      "type": "section-custom-code",
      "name": "Custom code",
      "settings": {
        "code": "\n<style>\n/* =========================================\n   SOLSTAR - Why Us Scroll Blocks\n   \uff08\u884c\u9593\u30bf\u30a4\u30c8\uff0b\u672c\u6587\u4ed8\u304d\uff09\n   ========================================= */\n\n.solstar-scroll-whyus {\n  position: relative;\n  height: 100vh;\n  width: 100%;\n  max-width: 100vw;\n  margin: 0 auto;\n  overflow-y: auto;\n  overflow-x: hidden;\n  overscroll-behavior-x: contain;\n  touch-action: pan-y;\n  scroll-snap-type: y mandatory; /* \u2605 \u518d\u5ea6 mandatory \u306b\u3057\u3066\u5fc5\u305a\u30b9\u30ca\u30c3\u30d7 */\n  background: #0D0326;\n  color: #ffffff;\n  font-family: system-ui, -apple-system, BlinkMacSystemFont, \"Segoe UI\", sans-serif;\n}\n\n/* \u30b9\u30af\u30ed\u30fc\u30eb\u30d0\u30fc\uff08\u4efb\u610f\u3067\u524a\u9664OK\uff09 */\n.solstar-scroll-whyus::-webkit-scrollbar {\n  width: 6px;\n}\n.solstar-scroll-whyus::-webkit-scrollbar-thumb {\n  background: rgba(255, 255, 255, 0.25);\n  border-radius: 999px;\n}\n\n.solstar-scroll-whyus__inner {\n  position: relative;\n  width: 100%;\n  max-width: 100%;\n}\n\n/* ===== \u5404\u30d6\u30ed\u30c3\u30af\u306e\u30ec\u30a4\u30a2\u30a6\u30c8 ===== */\n\n.solstar-block {\n  scroll-snap-align: center;  /* \u2605 \u30d6\u30ed\u30c3\u30af\u306e\u4e2d\u592e\u3067\u30b9\u30ca\u30c3\u30d7 */\n  scroll-snap-stop: always;   /* \u2605 \u9ad8\u901f\u30b9\u30af\u30ed\u30fc\u30eb\u3067\u3082\u5fc5\u305a\u3053\u3053\u3067\u6b62\u307e\u308b */\n  min-height: 100vh;\n  display: flex;\n  align-items: center;\n  justify-content: center;\n  padding: 3.5rem 8vw;\n  box-sizing: border-box;\n  text-align: center;\n  opacity: 0.6;\n  color: rgba(255, 255, 255, 0.7);\n  transition:\n    color 0.35s ease,\n    opacity 0.35s ease,\n    transform 0.35s ease;\n}\n\n.solstar-block__content {\n  max-width: 900px;\n  margin: 0 auto;\n}\n\n/* \u30bf\u30a4\u30c8\u30eb\u3068\u672c\u6587\uff1a\u884c\u9593\u30bf\u30a4\u30c8\u3081 */\n\n.solstar-block__title {\n  margin: 0 0 1rem;\n  font-size: clamp(1.6rem, 4vw, 2.4rem);\n  line-height: 1.18;\n}\n\n.solstar-block__body {\n  margin: 0;\n  font-size: 0.98rem;\n  line-height: 1.7;\n  opacity: 0.9;\n}\n\n/* ===== \u30a2\u30af\u30c6\u30a3\u30d6\u306a\u30d6\u30ed\u30c3\u30af\uff08\u4eca\u306e\u753b\u9762\u306e\u4e3b\u5f79\uff09 ===== */\n\n.solstar-block.is-active {\n  opacity: 1;\n  color: #ffffff;\n  transform: scale(1.02);\n}\n\n.solstar-block.is-active .solstar-block__title {\n  font-size: clamp(2.1rem, 5vw, 3.4rem);\n  line-height: 1.16;\n  letter-spacing: 0.04em;\n}\n\n.solstar-block.is-active .solstar-block__body {\n  font-size: 1rem;\n  line-height: 1.8;\n}\n\n/* ===== \u904e\u53bb\u30d6\u30ed\u30c3\u30af\uff08\u4e0a\u306b\u884c\u3063\u305f\u3082\u306e\uff09 ===== */\n\n.solstar-block.is-past {\n  opacity: 0.4;\n  color: rgba(255, 255, 255, 0.35);\n  transform: scale(0.96);\n}\n\n.solstar-block.is-past .solstar-block__title {\n  font-size: clamp(1.1rem, 2.2vw, 1.5rem);\n  line-height: 1.2;\n  letter-spacing: 0.08em;\n}\n\n.solstar-block.is-past .solstar-block__body {\n  font-size: 0.9rem;\n  line-height: 1.6;\n}\n\n/* ===== \u30d6\u30ed\u30c3\u30af1\uff08\u30bb\u30af\u30b7\u30e7\u30f3\u30bf\u30a4\u30c8\u30eb\u3063\u307d\u304f\uff09 ===== */\n\n.solstar-block--1 .solstar-block__eyebrow {\n  font-size: 0.9rem;\n  letter-spacing: 0.25em;\n  text-transform: uppercase;\n  opacity: 0.7;\n  margin-bottom: 1.2rem;\n}\n\n.solstar-block--1 .solstar-block__title-main {\n  font-size: clamp(2.4rem, 5vw, 3.6rem);\n  margin: 0;\n  line-height: 1.16;\n}\n\n.solstar-block--1.is-active .solstar-block__title-main {\n  font-size: clamp(2.8rem, 6vw, 4.2rem);\n  line-height: 1.14;\n}\n\n/* ===== \u30ec\u30b9\u30dd\u30f3\u30b7\u30d6\u5fae\u8abf\u6574 ===== */\n\n@media (max-width: 768px) {\n  .solstar-block {\n    padding: 3rem 1.8rem;\n  }\n\n  .solstar-block__title {\n    line-height: 1.22;\n  }\n}\n\n/* =========================================\n   Animista: scale-out-center\n   \u524d\u306e\u30d6\u30ed\u30c3\u30af\u306b\u4ed8\u4e0e\u3057\u3066\u7e2e\u5c0f\u30a2\u30cb\u30e1\u30fc\u30b7\u30e7\u30f3\n   ========================================= */\n\n.scale-out-center {\n\t-webkit-animation: scale-out-center 0.5s cubic-bezier(0.550, 0.085, 0.680, 0.530) both;\n\t        animation: scale-out-center 0.5s cubic-bezier(0.550, 0.085, 0.680, 0.530) both;\n}\n\n@-webkit-keyframes scale-out-center {\n  0% {\n    -webkit-transform: scale(1);\n            transform: scale(1);\n    opacity: 1;\n  }\n  100% {\n    -webkit-transform: scale(0);\n            transform: scale(0);\n    opacity: 1;\n  }\n}\n@keyframes scale-out-center {\n  0% {\n    -webkit-transform: scale(1);\n            transform: scale(1);\n    opacity: 1;\n  }\n  100% {\n    -webkit-transform: scale(0);\n            transform: scale(0);\n    opacity: 1;\n  }\n}\n</style>\n\n\n<section class=\"solstar-scroll-whyus\" id=\"solstar-scroll-whyus\">\n  <div class=\"solstar-scroll-whyus__inner\">\n\n    <!-- \u30d6\u30ed\u30c3\u30af1\uff1a\u30bb\u30af\u30b7\u30e7\u30f3\u30bf\u30a4\u30c8\u30eb -->\n    <section class=\"solstar-block solstar-block--1\" data-index=\"0\">\n      <div class=\"solstar-block__content\">\n        <p class=\"solstar-block__eyebrow\">Why Us</p>\n        <h2 class=\"solstar-block__title-main\">\n          SOLSTAR\u304c\u9078\u3070\u308c\u308b\u7406\u7531\uff08Why Us\uff09\n        </h2>\n      </div>\n    </section>\n\n    <!-- \u30d6\u30ed\u30c3\u30af2\uff1a\u6226\u7565 \u00d7 \u8a2d\u8a08 \u00d7 \u958b\u767a\u306e\u30ef\u30f3\u30b9\u30c8\u30c3\u30d7 -->\n    <section class=\"solstar-block solstar-block--2\" data-index=\"1\">\n      <div class=\"solstar-block__content\">\n        <h2 class=\"solstar-block__title\">\n          \u6226\u7565 \u00d7 \u8a2d\u8a08 \u00d7 \u958b\u767a\u306e\u30ef\u30f3\u30b9\u30c8\u30c3\u30d7\n        </h2>\n        <p class=\"solstar-block__body\">\n          \u30d6\u30e9\u30f3\u30c9\u306e\u65b9\u5411\u6027\u304b\u3089\u8981\u4ef6\u5b9a\u7fa9\u3001UI/UX\u8a2d\u8a08\u3001Shopify\u69cb\u7bc9\u307e\u3067\u3092\u4e00\u8cab\u5bfe\u5fdc\u3002\u5206\u65ad\u3055\u308c\u304c\u3061\u306a\u5de5\u7a0b\u3092\u30b7\u30fc\u30e0\u30ec\u30b9\u306b\u3064\u306a\u3050\u3053\u3068\u3067\u3001\u30d6\u30ec\u306a\u3044\u201c\u52dd\u3066\u308bEC\u201d\u3092\u6700\u77ed\u3067\u5b9f\u73fe\u3057\u307e\u3059\u3002\n        </p>\n      </div>\n    </section>\n\n    <!-- \u30d6\u30ed\u30c3\u30af3\uff1a\u5927\u898f\u6a21\u6848\u4ef6\u306e\u7d4c\u9a13\u5024\u3067\u201c\u4f38\u3073\u308bEC\u201d\u3092\u518d\u73fe -->\n    <section class=\"solstar-block solstar-block--3\" data-index=\"2\">\n      <div class=\"solstar-block__content\">\n        <h2 class=\"solstar-block__title\">\n          \u5927\u898f\u6a21\u6848\u4ef6\u306e\u7d4c\u9a13\u5024\u3067\u201c\u4f38\u3073\u308bEC\u201d\u3092\u518d\u73fe\n        </h2>\n        <p class=\"solstar-block__body\">\n          \u958b\u767a\u8cbb10\u5104\u5186\u898f\u6a21\u3001\u5e74\u9593\u58f2\u4e0a60\u5104\u5186\u8d85\u3068\u3044\u3063\u305f\u30cf\u30a4\u30ec\u30d9\u30eb\u6848\u4ef6\u3092\u591a\u6570\u62c5\u5f53\u3002\u84c4\u7a4d\u3055\u308c\u305f\u30c7\u30fc\u30bf\u3068\u30ca\u30ec\u30c3\u30b8\u3092\u5143\u306b\u3001\u5c0f\u301c\u4e2d\u898f\u6a21\u306e\u30d6\u30e9\u30f3\u30c9\u306b\u3082\u201c\u4f38\u3073\u308b\u30d1\u30bf\u30fc\u30f3\u201d\u3092\u518d\u73fe\u3057\u307e\u3059\u3002\n        </p>\n      </div>\n    </section>\n\n    <!-- \u30d6\u30ed\u30c3\u30af4\uff1a\u8d8a\u5883\u30fb\u30b0\u30ed\u30fc\u30d0\u30eb\u5bfe\u5fdc\u306e\u77e5\u898b -->\n    <section class=\"solstar-block solstar-block--4\" data-index=\"3\">\n      <div class=\"solstar-block__content\">\n        <h2 class=\"solstar-block__title\">\n          \u8d8a\u5883\u30fb\u30b0\u30ed\u30fc\u30d0\u30eb\u5bfe\u5fdc\u306e\u77e5\u898b\n        </h2>\n        <p class=\"solstar-block__body\">\n          \u591a\u8a00\u8a9e\u3001\u591a\u901a\u8ca8\u3001\u6d77\u5916\u914d\u9001\u3001\u30ed\u30fc\u30ab\u30e9\u30a4\u30ba\u6226\u7565\u307e\u3067\u30c8\u30fc\u30bf\u30eb\u3067\u30ab\u30d0\u30fc\u3002\u30b7\u30f3\u30ac\u30dd\u30fc\u30eb\u30fb\u30a2\u30e1\u30ea\u30ab\u30fb\u30e8\u30fc\u30ed\u30c3\u30d1\u306a\u3069\u3001\u6d77\u5916\u5e02\u5834\u5411\u3051Shopify\u69cb\u7bc9\u306e\u5b9f\u7e3e\u3092\u6d3b\u304b\u3057\u3001\u30b0\u30ed\u30fc\u30d0\u30eb\u5c55\u958b\u3092\u30b9\u30e0\u30fc\u30ba\u306b\u652f\u63f4\u3057\u307e\u3059\u3002\n        </p>\n      </div>\n    </section>\n\n    <!-- \u30d6\u30ed\u30c3\u30af5\uff1a\u30ea\u30ea\u30fc\u30b9\u5f8c\u306e\u904b\u7528\u6539\u5584\u30b5\u30dd\u30fc\u30c8 -->\n    <section class=\"solstar-block solstar-block--5\" data-index=\"4\">\n      <div class=\"solstar-block__content\">\n        <h2 class=\"solstar-block__title\">\n          \u30ea\u30ea\u30fc\u30b9\u5f8c\u306e\u904b\u7528\u6539\u5584\u30b5\u30dd\u30fc\u30c8\n        </h2>\n        <p class=\"solstar-block__body\">\n          \u516c\u958b\u304c\u30b4\u30fc\u30eb\u3067\u306f\u306a\u304f\u30b9\u30bf\u30fc\u30c8\u3002\u6570\u5024\u5206\u6790\u3001UI\u6539\u5584\u3001\u6a5f\u80fd\u8ffd\u52a0\u3001A/B\u30c6\u30b9\u30c8\u306a\u3069\u3001\u6210\u9577\u30d5\u30a7\u30fc\u30ba\u3092\u898b\u636e\u3048\u305f\u904b\u7528\u652f\u63f4\u3092\u7d99\u7d9a\u7684\u306b\u884c\u3044\u3001\u58f2\u4e0a\u6700\u5927\u5316\u3092\u4f34\u8d70\u3057\u307e\u3059\u3002\n        </p>\n      </div>\n    </section>\n\n  </div>\n</section>\n\n<script>\ndocument.addEventListener('DOMContentLoaded', function() {\n  const container = document.getElementById('solstar-scroll-whyus');\n  if (!container) return;\n\n  const blocks = Array.from(container.querySelectorAll('.solstar-block'));\n  if (!blocks.length) return;\n\n  let lastActiveIndex = -1;\n  let animationsEnabled = false;\n\n  const isContainerCentered = () => {\n    const rect = container.getBoundingClientRect();\n    const viewportHeight = window.innerHeight || document.documentElement.clientHeight;\n    const containerCenter = rect.top + rect.height / 2;\n    const upperBound = viewportHeight * 0.45;\n    const lowerBound = viewportHeight * 0.55;\n    return containerCenter >= upperBound && containerCenter <= lowerBound;\n  };\n\n  const setActive = (targetIndex) => {\n    if (!animationsEnabled) return;\n    if (targetIndex === lastActiveIndex || targetIndex < 0 || targetIndex >= blocks.length) return;\n\n    const prevBlock = lastActiveIndex >= 0 ? blocks[lastActiveIndex] : null;\n    if (prevBlock) {\n      prevBlock.classList.add('scale-out-center');\n      setTimeout(() => {\n        prevBlock.classList.remove('scale-out-center');\n      }, 550);\n    }\n\n    blocks.forEach((block, index) => {\n      block.classList.remove('is-active', 'is-past');\n      if (index < targetIndex) block.classList.add('is-past');\n    });\n\n    blocks[targetIndex].classList.add('is-active');\n    lastActiveIndex = targetIndex;\n  };\n\n  const getNearestIndex = () => {\n    const centerY = container.scrollTop + container.clientHeight / 2;\n    let nearest = 0;\n    let nearestDistance = Infinity;\n\n    blocks.forEach((block, index) => {\n      const rect = block.getBoundingClientRect();\n      const blockCenter = container.scrollTop + rect.top + rect.height / 2;\n      const distance = Math.abs(blockCenter - centerY);\n      if (distance < nearestDistance) {\n        nearestDistance = distance;\n        nearest = index;\n      }\n    });\n\n    return nearest;\n  };\n\n  let ticking = false;\n  const onScroll = () => {\n    if (ticking) return;\n    ticking = true;\n    window.requestAnimationFrame(() => {\n      if (!animationsEnabled && isContainerCentered()) {\n        animationsEnabled = true;\n        setActive(0);\n      }\n      if (animationsEnabled) {\n        const index = getNearestIndex();\n        setActive(index);\n      }\n      ticking = false;\n    });\n  };\n\n  container.addEventListener('scroll', onScroll, { passive: true });\n  window.addEventListener('resize', onScroll);\n  window.addEventListener('scroll', onScroll, { passive: true });\n});\n</script>\n",
        "width": "wrapper--full",
        "color_scheme": "scheme-10",
        "padding_top": 0,
        "padding_bottom": 0
      }
    },
