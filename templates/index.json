        "text_MqEBM9": {
          "type": "text",
          "settings": {
            "text": "<p>\u5f53\u793e\u306f\u3001Shopify\u3092\u6d3b\u7528\u3057\u305fEC\u30b5\u30a4\u30c8\u306e\u69cb\u7bc9\u30fb\u904b\u7528\u306b\u7279\u5316\u3057\u305f\u958b\u767a\u4f1a\u793e\u3067\u3059\u3002\u958b\u767a\u8cbb10\u5104\u5186\u8d85\u306e\u5927\u898f\u6a21EC\u30b5\u30a4\u30c8\u3084\u3001\u5e74\u9593\u58f2\u4e0a60\u5104\u5186\u4ee5\u4e0a\u306eShopify Plus\u30b5\u30a4\u30c8\u306e\u69cb\u7bc9\u30fb\u9577\u671f\u30b5\u30dd\u30fc\u30c8\u306e\u5b9f\u7e3e\u304c\u3042\u308a\u307e\u3059\u3002\u3055\u3089\u306b\u3001Shopify\u30a2\u30ab\u30c7\u30df\u30fc\u8a8d\u5b9a\u8cc7\u683c\u3092\u591a\u6570\u4fdd\u6709\u3057\u3066\u304a\u308a\u3001\u6700\u9069\u306a\u30bd\u30ea\u30e5\u30fc\u30b7\u30e7\u30f3\u3092\u81ea\u4fe1\u3092\u6301\u3063\u3066\u63d0\u4f9b\u3044\u305f\u3057\u307e\u3059\u3002</p>",
            "text_font_size": "body-medium",
            "padding_bottom": 0
          }
        }
